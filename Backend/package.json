{
    "name": "warehouse-backend",
    "version": "1.0.0",
    "main": "server.js",
    "scripts": {
        "start": "node src/server.js",
        "dev": "nodemon src/server.js",
        "setup-db": "npx sequelize-cli db:create --env master && npx sequelize-cli db:create --env development && npx sequelize-cli db:migrate --debug --env development && npx sequelize-cli db:seed:all --env development",
        "migrate": "npx sequelize-cli db:migrate",
        "migrate:undo": "npx sequelize-cli db:migrate:undo",
        "seed": "npx sequelize-cli db:seed:all"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "jsonwebtoken": "^9.0.2",
        "mssql": "^11.0.1",
        "multer": "^2.0.2",
        "node-windows": "^1.0.0-beta.8",
        "sequelize": "^6.37.3",
        "tedious": "^19.2.0",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "nodemon": "^3.1.0",
        "sequelize-cli": "^6.6.2"
    }
}
